# dependencies & build output
web/node_modules/
web/.next/
web/out/
web/.vercel/
web/next-env.d.ts

# logs
*.log
npm-debug.log*

# scratch dev tooling (headless screenshot / scraper scripts)
web/*.mjs
# ...but never ignore real config files (postcss/eslint) — Tailwind needs these
!web/*.config.mjs

# raw, ungraded image pulls
web/public/images/_raw/

# os / editor
.DS_Store
Thumbs.db
